# --- Rust / Cargo 関連 ---
# コンパイルで生成される一時ファイル・実行ファイル（必須）
/target/
/**/target/

# rustfmt が生成するバックアップファイル
**/*.rs.bk

# Windows環境（MSVC）で生成されるデバッグ情報ファイル
*.pdb

# 内部コンパイラエラー時に出力されるスタックトレース
rustc-ice-*.txt


# --- お使いのエディタ (Zed) 関連 ---
# Zedエディタの設定やキャッシュ
.zed/


# --- OS固有の一時ファイル（任意、入れておくと安全） ---
# macOS
.DS_Store
# Windows
Thumbs.db

image.ppm
